<%= form_with(model: weight, local: true) do |form| %>
  <% if weight.errors.any? %>
    <div id="error_explanation" class="mb-4 rounded-xl border border-rose-200 bg-rose-100 p-4 text-rose-800">
      <h2 class="font-semibold"><%= pluralize(weight.errors.count, t('error.single')) %> <%= t('error.saved') %></h2>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% weight.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="tw-card">
    <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      <%= t('weight.alert') %>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :kg, class: "tw-label" %>
        <%= form.number_field :kg, step: :any, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :weight_date, class: "tw-label" %>
        <%= form.date_field :weight_date, class: "tw-input" %>
      </div>
    </div>

    <div class="mt-5">
      <%= form.submit class: 'tw-btn-primary' %>
    </div>
  </section>
<% end %>
