<nav class="fit-nav fit-nav-shell mb-6 rounded-2xl bg-gradient-to-r from-emerald-700 to-teal-600 p-4 text-white shadow-lg">
  <div class="fit-nav-inner flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <%= link_to root_path, class: "fit-nav-brand inline-flex items-center gap-2 text-xl font-bold tracking-tight text-white no-link-underline" do %>
      <i class="fa fa-heartbeat" aria-hidden="true"></i>
      <span><%= t('title') %></span>
    <% end %>

    <div class="fit-nav-actions flex flex-wrap items-center gap-2">
      <% if current_user.present? %>
        <%= link_to new_weight_path, data: { turbo_frame: "main" }, class: "fit-nav-link tw-btn rounded-lg bg-white/20 text-white hover:bg-white/30 no-link-underline" do %>
          <i class="fa fa-balance-scale mr-2" aria-hidden="true"></i><%= t('weight.update') %>
        <% end %>
        <%= link_to workouts_path, data: { turbo_frame: "main" }, class: "fit-nav-link tw-btn rounded-lg bg-white/20 text-white hover:bg-white/30 no-link-underline" do %>
          <i class="fa fa-list mr-2" aria-hidden="true"></i><%= t('workout.title') %>
        <% end %>
        <%= link_to new_workout_path, data: { turbo_frame: "main" }, class: "fit-nav-link tw-btn rounded-lg bg-white/20 text-white hover:bg-white/30 no-link-underline" do %>
          <i class="fa fa-plus-circle mr-2" aria-hidden="true"></i><%= t('workout.new') %>
        <% end %>
        <%= link_to new_diet_path, data: { turbo_frame: "main" }, class: "fit-nav-link tw-btn rounded-lg bg-white/20 text-white hover:bg-white/30 no-link-underline" do %>
          <i class="fa fa-cutlery mr-2" aria-hidden="true"></i><%= t('diet.new') %>
        <% end %>
        <%= link_to chats_path, class: "fit-nav-link fit-nav-link-accent tw-btn rounded-lg bg-amber-300 text-slate-900 hover:bg-amber-200 no-link-underline" do %>
          <i class="fa fa-magic mr-2" aria-hidden="true"></i><%= t('diet.suggestions') %>
        <% end %>
        <%= link_to edit_user_registration_path, class: "fit-nav-link tw-btn rounded-lg border border-slate-200 bg-transparent text-white hover:bg-white/15 no-underline no-link-underline" do %>
          <i class="fa fa-user mr-2" aria-hidden="true"></i><%= t('profile') %>
        <% end %>
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: t('sure') }, class: "fit-nav-link tw-btn rounded-lg border border-white/70 bg-transparent text-white hover:bg-white/15 no-underline no-link-underline" do %>
          <i class="fa fa-sign-out mr-2" aria-hidden="true"></i><%= t('sign.out') %>
        <% end %>
      <% else %>
        <%= link_to t('sign.up'), new_user_registration_path, class: "fit-nav-link tw-btn rounded-lg bg-white text-emerald-700 hover:bg-emerald-50 no-link-underline" %>
        <%= link_to t('sign.in'), new_user_session_path, class: "fit-nav-link fit-nav-link-accent tw-btn rounded-lg bg-amber-300 text-slate-900 hover:bg-amber-200 no-link-underline" %>
      <% end %>

      <div class="fit-theme-toggle-item" role="group" aria-label="Tema">
        <button id="theme-toggle" type="button" class="theme-toggle" role="switch" aria-label="Change theme" aria-checked="false" aria-pressed="false" title="Theme">
          <span class="theme-toggle-icon theme-toggle-icon-sun" aria-hidden="true">
            <i class="fa fa-sun-o" aria-hidden="true"></i>
          </span>
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-thumb"></span>
          </span>
          <span class="theme-toggle-icon theme-toggle-icon-moon" aria-hidden="true">
            <i class="fa fa-moon-o" aria-hidden="true"></i>
          </span>
        </button>
      </div>
    </div>
  </div>
</nav>
