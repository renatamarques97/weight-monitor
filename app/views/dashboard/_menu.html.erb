<nav class="fit-nav fit-nav-shell mb-6 rounded-2xl bg-gradient-to-r from-emerald-700 to-teal-600 p-4 text-white shadow-lg">
  <div class="fit-nav-inner flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <%= link_to root_path, class: "fit-nav-brand inline-flex items-center gap-2 text-xl font-bold tracking-tight text-white no-link-underline" do %>
      <i class="fa fa-heartbeat" aria-hidden="true"></i>
      <span><%= t('title') %></span>
    <% end %>

    <div class="fit-nav-actions flex flex-wrap items-center gap-2">
      <% if current_user.present? %>
        <%= link_to new_weight_path, data: { turbo_frame: "main" }, class: "fit-nav-link fit-nav-link-neutral tw-btn rounded-lg no-link-underline" do %>
          <i class="fa fa-balance-scale mr-2" aria-hidden="true"></i><%= t('weight.update') %>
        <% end %>
        <%= link_to workouts_path, data: { turbo_frame: "main" }, class: "fit-nav-link fit-nav-link-neutral tw-btn rounded-lg no-link-underline" do %>
          <i class="fa fa-list mr-2" aria-hidden="true"></i><%= t('workout.title') %>
        <% end %>
        <%= link_to new_workout_path, data: { turbo_frame: "main" }, class: "fit-nav-link fit-nav-link-neutral tw-btn rounded-lg no-link-underline" do %>
          <i class="fa fa-plus-circle mr-2" aria-hidden="true"></i><%= t('workout.new') %>
        <% end %>
        <%= link_to new_diet_path, data: { turbo_frame: "main" }, class: "fit-nav-link fit-nav-link-neutral tw-btn rounded-lg no-link-underline" do %>
          <i class="fa fa-cutlery mr-2" aria-hidden="true"></i><%= t('diet.new') %>
        <% end %>
        <%= link_to chats_path, class: "fit-nav-link fit-nav-link-accent tw-btn rounded-lg no-link-underline" do %>
          <i class="fa fa-magic mr-2" aria-hidden="true"></i><%= t('diet.suggestions') %>
        <% end %>
        <div class="relative">
          <%= render "dashboard/user_menu" %>
        </div>
      <% else %>
        <%= link_to t('sign.up'), new_user_registration_path, class: "fit-nav-link fit-nav-link-plain tw-btn rounded-lg no-link-underline" %>
        <%= link_to t('sign.in'), new_user_session_path, class: "fit-nav-link fit-nav-link-accent tw-btn rounded-lg no-link-underline" %>
      <% end %>
    </div>
  </div>
</nav>
