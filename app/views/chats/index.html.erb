<%= render "dashboard/menu" %>

<section class="tw-card" data-controller="chat" data-chat-user-label="<%= t('chat.user_label') %>" data-chat-assistant-label="<%= t('chat.assistant_label') %>">
  <h1 class="mb-2 text-2xl font-bold tracking-tight text-slate-900"><%= t('diet.suggestions') %></h1>
  <p class="mb-4 text-sm text-slate-600"><%= t('chat.describe_goals') %></p>

  <section class="max-h-[55vh] min-h-[300px] overflow-y-auto rounded-xl border border-slate-200 bg-slate-50 p-4" data-chat-target="conversation" data-action="scroll->chat#onScroll" data-chat-current-page="<%= @page %>">
    <% if @serialized_chat_messages.empty? %>
      <p class="text-xs text-slate-400 italic">No messages yet.</p>
    <% end %>
    <% @serialized_chat_messages.each do |message| %>
      <%= render partial: "chats/message", locals: { message: message } %>
    <% end %>
  </section>

  <%= form_with data: { action: "chat#generateResponse" }, html: { class: "mt-4 grid gap-3" } do |form| %>
    <div>
      <%= form.label :objective, t('chat.objective_label'), class: "tw-label" %>
      <%= form.select :objective,
            [
              [t('chat.objectives.weight_loss'), 'weight_loss'],
              [t('chat.objectives.hypertrophy'), 'hypertrophy'],
              [t('chat.objectives.running_performance'), 'running_performance'],
              [t('chat.objectives.general_health'), 'general_health']
            ],
            {},
            { class: "tw-input", data: { chat_target: "objective" } } %>
    </div>
    <div class="grid gap-3 md:grid-cols-[1fr_auto] md:items-end">
      <div>
        <%= form.label :message, t('chat.message'), class: "tw-label" %>
        <%= form.text_area :message, id: "prompt", rows: 3, class: "tw-input", placeholder: t('chat.example'), data: { chat_target: "prompt" } %>
      </div>
      <div>
        <%= form.submit t('send'), class: "tw-btn-primary w-full md:w-auto" %>
      </div>
    </div>
  <% end %>
</section>
