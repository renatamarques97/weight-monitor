<%= render "dashboard/menu" %>

<section class="tw-card" data-controller="chat" data-chat-user-label-value="<%= t('chat.user_label') %>" data-chat-assistant-label-value="<%= t('chat.assistant_label') %>">
  <h1 class="mb-2 text-2xl font-bold tracking-tight fit-text-primary"><%= t('diet.suggestions') %></h1>
  <p class="mb-4 text-sm fit-text-secondary"><%= t('chat.describe_goals') %></p>

  <section class="max-h-[55vh] min-h-[300px] overflow-y-auto rounded-xl border fit-border-subtle fit-surface-muted p-4 shadow-inner" data-chat-target="conversation" data-action="scroll->chat#onScroll" data-chat-current-page="<%= @page %>">
    <% if @serialized_chat_messages.empty? %>
      <p class="text-xs fit-text-secondary italic opacity-70">No messages yet.</p>
    <% end %>
    <% @serialized_chat_messages.each do |message| %>
      <%= render partial: "chats/message", locals: { message: message } %>
    <% end %>
  </section>

  <%= form_with data: { action: "chat#generateResponse" }, html: { class: "mt-4 grid gap-3" } do |form| %>
    <div>
      <%= form.label :objective, t('chat.objective_label'), class: "tw-label" %>
      <%= form.select :objective,
            [
              [t('chat.objectives.weight_loss'), 'weight_loss'],
              [t('chat.objectives.hypertrophy'), 'hypertrophy'],
              [t('chat.objectives.running_performance'), 'running_performance'],
              [t('chat.objectives.general_health'), 'general_health']
            ],
            {},
            { class: "tw-input", data: { chat_target: "objective" } } %>
    </div>
    <div>
      <%= form.label :message, t('chat.message'), class: "tw-label" %>
      <div class="relative mt-1 flex items-end rounded-lg border fit-border-subtle fit-surface-card p-1 shadow-sm transition-all focus-within:border-emerald-500 focus-within:ring-2 focus-within:ring-emerald-200">
        <%= form.text_area :message, id: "prompt", rows: 1,
              class: "grow resize-none border-0 bg-transparent py-2 pl-2 pr-2 text-sm outline-none focus:ring-0 overflow-y-hidden leading-5 fit-text-primary",
              placeholder: t('chat.example'),
              data: { chat_target: "prompt", action: "input->chat#resizePrompt keydown->chat#submitOnEnter" } %>
        <div class="flex-none p-1">
          <button type="submit" style="cursor: pointer;" class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-600 text-white hover:bg-emerald-700 hover:scale-105 active:scale-95 transition-all duration-200" aria-label="<%= t('send') %>">
            <i class="fa fa-arrow-up" style="rotate: 90deg;" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </div>
  <% end %>
</section>
