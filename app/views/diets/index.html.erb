<%= render "dashboard/menu" %>

<section class="tw-card">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= t('diet.title') %></h1>
    <%= link_to t('diet.new'), new_diet_path, class: "tw-btn-primary" %>
  </div>

  <div class="overflow-x-auto rounded-xl border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200 bg-white text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t('diet.start_date') %></th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t('diet.end_date') %></th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t('diet.initial_weight') %></th>
          <th class="px-4 py-3 text-left font-semibold text-slate-700"><%= t('diet.target_weight') %></th>
          <th class="px-4 py-3 text-right font-semibold text-slate-700"><%= t('actions') %></th>
        </tr>
      </thead>

      <tbody class="divide-y divide-slate-100">
        <% @diets.each do |diet| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= diet.start_date.strftime("%m/%d/%Y") %></td>
            <td class="px-4 py-3"><%= diet.end_date.strftime("%m/%d/%Y") %></td>
            <td class="px-4 py-3"><%= diet.initial_weight %></td>
            <td class="px-4 py-3"><%= diet.target_weight %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to t('show'), diet, class: "tw-btn-soft py-1.5" %>
              <%= link_to edit_diet_path(diet), class: "inline-flex rounded-lg border border-slate-300 px-3 py-2 text-slate-600 hover:bg-slate-100" do %>
                <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
              <% end %>
              <%= link_to diet, data: { turbo_method: :delete, turbo_confirm: t('sure') }, class: "inline-flex rounded-lg border border-rose-300 px-3 py-2 text-rose-700 hover:bg-rose-50" do %>
                <i class="fa fa-trash" aria-hidden="true"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

