<%= render "dashboard/menu" %>

<section class="tw-card">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold tracking-tight fit-text-primary"><%= t('diet.title') %></h1>
    <%= link_to t('diet.new'), new_diet_path, class: "tw-btn-primary" %>
  </div>

  <div class="overflow-x-auto rounded-xl border fit-border-subtle">
    <table class="min-w-full text-sm">
      <thead class="fit-surface-muted">
        <tr>
          <th class="px-4 py-3 text-left font-semibold fit-text-primary"><%= t('diet.start_date') %></th>
          <th class="px-4 py-3 text-left font-semibold fit-text-primary"><%= t('diet.end_date') %></th>
          <th class="px-4 py-3 text-left font-semibold fit-text-primary"><%= t('diet.initial_weight') %></th>
          <th class="px-4 py-3 text-left font-semibold fit-text-primary"><%= t('diet.target_weight') %></th>
          <th class="px-4 py-3 text-right font-semibold fit-text-primary"><%= t('actions') %></th>
        </tr>
      </thead>

      <tbody class="fit-surface-card fit-divide-subtle">
        <% @diets.each do |diet| %>
          <tr class="fit-hover-surface-muted">
            <td class="px-4 py-3"><%= diet.start_date.strftime("%m/%d/%Y") %></td>
            <td class="px-4 py-3"><%= diet.end_date.strftime("%m/%d/%Y") %></td>
            <td class="px-4 py-3"><%= diet.initial_weight %></td>
            <td class="px-4 py-3"><%= diet.target_weight %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to diet, class: "fit-icon-btn fit-icon-btn-show", title: t('show'), aria: { label: t('show') } do %>
                <i class="fa fa-eye" aria-hidden="true"></i>
              <% end %>
              <%= link_to edit_diet_path(diet), data: { turbo_frame: "main" }, class: "fit-icon-btn fit-icon-btn-edit", title: t('edit'), aria: { label: t('edit') } do %>
                <i class="fa fa-pencil text-lg"></i>
              <% end %>
              <%= link_to diet, data: { turbo_method: :delete, turbo_confirm: t('sure') }, class: "fit-icon-btn fit-icon-btn-delete", title: t('remove'), aria: { label: t('remove') } do %>
                <i class="fa fa-trash" aria-hidden="true"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

