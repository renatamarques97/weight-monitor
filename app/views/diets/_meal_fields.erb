<div class="mb-3 rounded-xl border border-slate-200 bg-slate-50 p-4" data-nested-form-wrapper>
  <%= f.hidden_field :id if f.object.persisted? %>
  <%= f.hidden_field :_destroy, value: "0" %>

  <div class="grid gap-3 md:grid-cols-[1fr_2fr_1fr_auto] md:items-end">
    <div>
      <%= f.label :schedule, class: "tw-label" %>
      <%= f.time_field :schedule, class: "tw-input" %>
    </div>

    <div>
      <%= f.label :description, class: "tw-label" %>
      <%= f.text_field :description, class: "tw-input" %>
    </div>

    <div>
      <%= f.label :meal_type, class: "tw-label" %>
      <%= f.select :meal_type, Meal.meal_type.options, {}, class: "tw-input" %>
    </div>

    <div>
      <button type="button" class="tw-btn-danger w-full md:w-auto" data-action="nested-form#remove">
        <i class="fa fa-trash" aria-hidden="true"></i>
      </button>
    </div>
  </div>
</div>

