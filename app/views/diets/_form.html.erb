<%= form_with(model: diet, local: true) do |form| %>
  <% if diet.errors.any? %>
    <div id="error_explanation" class="mb-4 rounded-xl border border-rose-200 bg-rose-100 p-4 text-rose-800">
      <h2 class="font-semibold">
        <%= pluralize(diet.errors.count, t('error.single')) %>
        <%= t('error.saved') %>
      </h2>

      <ul class="mt-2 list-disc pl-5 text-sm">
        <% diet.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="tw-card" data-controller="nested-form">
    <h2 class="mb-4 text-xl font-bold text-slate-900"><%= t('diet.singular') %></h2>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <div class="xl:col-span-2">
        <%= form.label :start_date, class: "tw-label" %>
        <%= form.date_field :start_date, class: "tw-input" %>
      </div>

      <div class="xl:col-span-2">
        <%= form.label :end_date, class: "tw-label" %>
        <%= form.date_field :end_date, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :initial_weight, class: "tw-label" %>
        <%= form.number_field :initial_weight, step: :any, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :target_weight, class: "tw-label" %>
        <%= form.number_field :target_weight, step: :any, class: "tw-input" %>
      </div>
    </div>

    <div class="my-5 h-px bg-slate-200"></div>

    <div class="mb-3 flex items-center justify-between gap-3">
      <h3 class="text-lg font-semibold text-slate-900"><%= t('meal.title') %></h3>
      <button type="button" class="tw-btn-primary" data-action="nested-form#add">
        <i class="fa fa-plus mr-2" aria-hidden="true"></i><%= t('meal.add') %>
      </button>
    </div>

    <template data-nested-form-target="template">
      <%= form.fields_for :meals, Meal.new, child_index: "NEW_RECORD" do |ff| %>
        <%= render 'meal_fields', f: ff %>
      <% end %>
    </template>

    <div data-nested-form-target="list">
      <%= form.fields_for :meals do |ff| %>
        <%= render 'meal_fields', f: ff %>
      <% end %>
    </div>

    <div class="mt-4">
      <%= form.submit class: 'tw-btn-primary' %>
    </div>
  </section>
<% end %>
