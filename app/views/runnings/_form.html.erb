<%= form_with(model: running, local: true) do |form| %>
  <% if running.errors.any? %>
    <div id="error_explanation" class="mb-4 rounded-xl border border-rose-200 bg-rose-100 p-4 text-rose-800">
      <h2 class="font-semibold">
        <%= pluralize(running.errors.count, t('error.single')) %>
        <%= t('error.saved') %>
      </h2>

      <ul class="mt-2 list-disc pl-5 text-sm">
        <% running.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="tw-card">
    <h2 class="mb-3 text-xl font-semibold text-slate-900"><%= t('running.title') %></h2>

    <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      <%= t('running.alert') %>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <div>
        <%= form.label :distance, class: "tw-label" %>
        <%= form.number_field :distance, step: :any, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :duration, class: "tw-label" %>
        <%= form.number_field :duration, step: :any, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :running_date, class: "tw-label" %>
        <%= form.date_field :running_date, class: "tw-input" %>
      </div>
    </div>

    <div class="mt-5">
      <%= form.submit class: 'tw-btn-primary' %>
    </div>
  </section>
<% end %>
