<%= render "dashboard/menu" %>

<section class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-sm">
  <h1 class="mb-4 text-2xl font-bold tracking-tight text-slate-900">Edit <%= resource_name.to_s.humanize %></h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, data: { turbo: false } }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-3">
      <%= f.label :name, class: "tw-label" %>
      <%= f.text_field :name, autocomplete: "name", class: "tw-input" %>
    </div>

    <div class="mb-3">
      <%= f.label :height, class: "tw-label" %>
      <%= f.text_field :height, class: "tw-input" %>
    </div>

    <div class="mb-3">
      <%= f.label :email, class: "tw-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "tw-input" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="mb-3 rounded-lg border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-800">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
    <% end %>

    <div class="mb-3">
      <%= f.label :password, class: "tw-label" %>
      <small class="mb-1 block text-xs text-slate-500">leave blank if you don't want to change it</small>
      <%= f.password_field :password, autocomplete: "new-password", class: "tw-input" %>
      <% if @minimum_password_length %>
        <small class="mt-1 block text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</small>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :password_confirmation, class: "tw-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "tw-input" %>
    </div>

    <div class="mb-3">
      <%= f.label :current_password, class: "tw-label" %>
      <small class="mb-1 block text-xs text-slate-500">we need your current password to confirm your changes</small>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "tw-input" %>
    </div>

    <div class="mb-4">
      <%= f.submit "Update", class: "tw-btn-primary w-full" %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= button_to "Cancel my account", registration_path(resource_name), data: { turbo_confirm: "Are you sure?" }, method: :delete, class: "tw-btn-danger w-full" %>
  </div>

  <%= link_to t('back'), root_path, class: "tw-btn-soft w-full" %>
</section>
