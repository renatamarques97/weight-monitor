<div class="mt-3 flex flex-col gap-2 text-sm">
  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to t('devise.links.forgot_password') , new_password_path(resource_name), class: "fit-text-accent fit-hover-text-accent hover:underline" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to t('devise.links.no_confirmation') , new_confirmation_path(resource_name), class: "fit-text-accent fit-hover-text-accent hover:underline" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to t('devise.links.no_unlock') , new_unlock_path(resource_name), class: "fit-text-accent fit-hover-text-accent hover:underline" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= link_to t('devise.links.sign_in_with', provider: OmniAuth::Utils.camelize(provider)), omniauth_authorize_path(resource_name, provider), class: "fit-text-accent fit-hover-text-accent hover:underline" %>
    <% end %>
  <% end %>
</div>
