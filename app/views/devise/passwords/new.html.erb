<%= render "dashboard/menu" %>

<section class="mx-auto max-w-xl rounded-2xl border fit-border-subtle fit-surface-card p-6 shadow-sm">
  <h1 class="mb-4 text-2xl font-bold tracking-tight fit-text-primary">Forgot your password?</h1>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, data: { turbo: false } }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-3">
      <%= f.label :email, class: "tw-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "tw-input" %>
    </div>

    <div class="mb-4">
      <%= f.submit "Send me reset password instructions", class: "tw-btn-primary w-full" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</section>
