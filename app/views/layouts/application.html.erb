<!DOCTYPE html>
<html>
  <head>
    <title>Fit Tracker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script>
      (function() {
        var availableThemes = ["light", "dark"];
        var savedTheme = localStorage.getItem("fit_tracker_theme");
        var resolvedTheme = availableThemes.includes(savedTheme) ? savedTheme : "light";
        document.documentElement.dataset.theme = resolvedTheme;
        console.log("[Theme Init] Set to:", resolvedTheme);
      })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js" defer></script>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "font-awesome", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-theme-shell min-h-screen">
    <main class="mx-auto max-w-7xl px-4 py-6 md:px-8 md:py-10">
      <% if notice.present? %>
        <div class="fit-flash fit-flash-notice" role="status"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="fit-flash fit-flash-alert" role="alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
