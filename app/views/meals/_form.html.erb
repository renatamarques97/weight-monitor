<%= form_with(model: meal, local: true) do |form| %>
  <% if meal.errors.any? %>
    <div id="error_explanation" class="mb-4 rounded-xl border border-rose-200 bg-rose-100 p-4 text-rose-800">
      <h2 class="font-semibold"><%= pluralize(meal.errors.count, t('error.single')) %> <%= t('error.saved') %></h2>
      <ul class="mt-2 list-disc pl-5 text-sm">
        <% meal.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="tw-card">
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :schedule, class: "tw-label" %>
        <%= form.time_field :schedule, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :meal_type, class: "tw-label" %>
        <%= form.text_field :meal_type, class: "tw-input" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :description, class: "tw-label" %>
        <%= form.text_area :description, rows: 3, class: "tw-input" %>
      </div>

      <div>
        <%= form.label :diet_id, class: "tw-label" %>
        <%= form.text_field :diet_id, class: "tw-input" %>
      </div>
    </div>

    <div class="mt-5">
      <%= form.submit class: 'tw-btn-primary' %>
    </div>
  </section>
<% end %>
