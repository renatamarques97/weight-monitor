<section class="tw-card">
  <h1 class="mb-4 text-2xl font-bold tracking-tight fit-text-primary"><%= t('meal.singular') %></h1>

  <p class="mb-1"><strong><%= t('meal.schedule') %>:</strong> <%= @meal.schedule %></p>
  <p class="mb-1"><strong><%= t('meal.description') %>:</strong> <%= @meal.description %></p>
  <p class="mb-4"><strong><%= t('meal.type') %>:</strong> <%= @meal.meal_type %></p>

  <%= link_to t('edit'), edit_meal_path(@meal), class: 'tw-btn-primary' %>
  <%= link_to t('meal.back'), meals_path, class: 'tw-btn-soft' %>
</section>
