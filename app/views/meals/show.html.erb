<section class="tw-card">
  <h1 class="mb-4 text-2xl font-bold tracking-tight text-slate-900">Meal</h1>

  <p class="mb-1"><strong>Schedule:</strong> <%= @meal.schedule %></p>
  <p class="mb-1"><strong>Description:</strong> <%= @meal.description %></p>
  <p class="mb-4"><strong>Meal type:</strong> <%= @meal.meal_type %></p>

  <%= link_to 'Edit', edit_meal_path(@meal), class: 'tw-btn-primary' %>
  <%= link_to 'Back', meals_path, class: 'tw-btn-soft' %>
</section>
