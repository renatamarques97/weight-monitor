<div data-workout-form-target="martialArtsFields" class="md:col-span-2 grid gap-4 md:grid-cols-2" style="display: none;">
  <div>
    <%= form.label "details[style]", t('workout.details.style'), class: "tw-label" %>
    <%= form.select "details[style]",
          options_for_select(Details::MartialArts::VALID_STYLES.map { |s| [s.titleize, s] }, (form.object.respond_to?(:details) && form.object.details.respond_to?(:style)) ? form.object.details.style : nil),
          { include_blank: true },
          class: "tw-input" %>
  </div>
  <div>
    <%= form.label "details[belt]", t('workout.details.belt'), class: "tw-label" %>
    <%= form.text_field "details[belt]", class: "tw-input", value: (form.object.respond_to?(:details) && form.object.details.respond_to?(:belt)) ? form.object.details.belt : nil %>
  </div>
</div>
