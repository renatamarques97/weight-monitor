<%= render "dashboard/menu" %>

<turbo-frame id="main">
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold tracking-tight fit-text-primary"><%= t('workout.title') %></h1>
  <%= link_to new_workout_path, data: { turbo_frame: "main" }, class: "tw-btn-primary" do %>
    <i class="fa fa-plus mr-2"></i><%= t('workout.new') %>
  <% end %>
</div>


<div class="mb-6 overflow-x-auto no-scrollbar">
  <div class="flex gap-2 p-1">
    <%= link_to workouts_path, 
          class: "px-4 py-2 rounded-xl border text-sm font-semibold transition-all #{params[:type].blank? ? 'fit-filter-active' : 'fit-surface-card fit-text-secondary fit-border-subtle fit-hover-border-strong'}" do %>
      All
    <% end %>
    
    <% WorkoutType::MAPPING.each_key do |sport| %>
      <%= link_to workouts_path(type: sport), 
            class: "px-4 py-2 rounded-xl border text-sm font-semibold transition-all flex items-center gap-2 #{params[:type] == sport.to_s ? 'fit-filter-active' : 'fit-surface-card fit-text-secondary fit-border-subtle fit-hover-border-strong'}" do %>
        <i class="fa <%= WorkoutType::ICONS[sport] %>" style="color: <%= params[:type] == sport.to_s ? 'white' : WorkoutType::COLORS[sport] %>"></i>
        <%= t("workout.types.#{sport}") %>
      <% end %>
    <% end %>
  </div>
</div>

<section class="tw-card overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="fit-surface-muted">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold fit-text-secondary uppercase tracking-wider"><%= t('workout.type') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold fit-text-secondary uppercase tracking-wider"><%= t('workout.date') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold fit-text-secondary uppercase tracking-wider"><%= t('workout.duration') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold fit-text-secondary uppercase tracking-wider"><%= t('workout.distance') %></th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-semibold fit-text-secondary uppercase tracking-wider"><%= t('actions') %></th>
        </tr>
      </thead>
      <tbody class="fit-surface-card fit-divide-subtle">
        <% @workouts.each do |workout| %>
          <tr class="fit-hover-surface-muted transition-colors">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg" style="color: <%= WorkoutType::COLORS[workout.workout_type.to_sym] %>">
                  <i class="fa <%= WorkoutType::ICONS[workout.workout_type.to_sym] %>"></i>
                </span>
                <span class="text-sm font-medium fit-text-primary"><%= t("workout.types.#{workout.workout_type}") %></span>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm fit-text-secondary">
              <%= workout.workout_date.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm fit-text-secondary">
              <%= workout.duration %> min
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm fit-text-secondary">
              <%= workout.distance.present? ? "#{workout.distance} km" : "-" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <div class="flex justify-end gap-2">
                <%= link_to edit_workout_path(workout), data: { turbo_frame: "main" }, class: "fit-icon-btn fit-icon-btn-edit", title: t('edit'), aria: { label: t('edit') } do %>
                  <i class="fa fa-pencil" aria-hidden="true"></i>
                <% end %>
                <%= link_to workout_path(workout), data: { turbo_method: :delete, turbo_confirm: t('sure') }, class: "fit-icon-btn fit-icon-btn-delete", title: t('remove'), aria: { label: t('remove') } do %>
                  <i class="fa fa-trash" aria-hidden="true"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% if @workouts.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center">
              <div class="fit-text-secondary">
                <i class="fa fa-calendar-o text-4xl mb-2"></i>
                <p><%= t('workout.no_records', sport: t('workout.title')) %></p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
</turbo-frame>
